DATABASE_URL=postgresql://postgres:postgres@localhost:5432/architect?schema=public

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

PORT=4000
CORS_ORIGIN=http://localhost:3000

PUBLIC_URL=http://localhost:4000

# Cloudinary — đăng ký free tại https://cloudinary.com
# Vào Dashboard → copy Cloud name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret

# Gmail SMTP example. Use an App Password, not your real Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM="Architect Portfolio <your-gmail@gmail.com>"
MAIL_TO=architect@example.com

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
